/*
Problem: 3120. Count the Number of Special Characters I
Platform: LeetCode
Difficulty: Easy
*/

class Solution {
public:
    int numberOfSpecialChars(string word) {
        unordered_set<char> lower, upper;

        for(char ch : word) {
            if(islower(ch))
                lower.insert(ch);
            else
                upper.insert(ch);
        }

        int count = 0;

        for(char ch = 'a'; ch <= 'z'; ch++) {
            if(lower.count(ch) && upper.count(toupper(ch)))
                count++;
        }

        return count;
    }
};
