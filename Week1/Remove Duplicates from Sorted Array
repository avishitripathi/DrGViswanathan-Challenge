/*
Problem: 26. Remove Duplicates from Sorted Array
Platform: LeetCode
Difficulty: Easy
*/

class Solution {
public:
    int removeDuplicates(vector<int>& nums) {
        int n = nums.size();
        int k = 0;
        for (int i=1; i<n; i++){
            if (nums[i] != nums[k]){
                nums[k+1] = nums[i];
                k++;
            }
        }
        return k+1;
        
    }
};
