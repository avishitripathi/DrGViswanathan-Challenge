/*
Problem: 876. Middle of the Linked List
Topic: Linked List
Platform: LeetCode
Difficulty: Easy
*/

class Solution {
public:
    ListNode* middleNode(ListNode* head) {
        ListNode* slow = head;
        ListNode* fast = head;
        while(fast != NULL && fast->next != NULL){
            slow = slow->next;
            fast = fast->next->next;
        }
        return slow;
        
    }

};
