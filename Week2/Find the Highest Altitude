/*
Problem: 1732. Find the Highest Altitude
Topic: Arrays
Platform: LeetCode
Difficulty: Easy
*/

class Solution {
public:
    int largestAltitude(vector<int>& gain) {
        int n = gain.size();

        vector<int> alt(n + 1, 0);
        for(int i=0; i<n; i++){
            alt[i+1] = alt[i]+gain[i];
        }

        int highest = INT_MIN;

        for (int i = 0; i <= n; i++) {
            highest = max(highest, alt[i]);
        }
        return highest;
    }
};

