/*
Problem: 141. Linked List Cycle
Topic: Linked List
Platform: LeetCode
Difficulty: Easy
*/

class Solution {
public:
    bool hasCycle(ListNode *head) {
        ListNode* slow= head;
        ListNode* fast = head;

        while(fast!= NULL && fast->next != NULL){
            slow = slow->next;
            fast = fast->next->next;
            if(slow == fast){
                return true;
            }

        }
        return false;
    }
};
